@* Pages/Shared/_EmployeeModals.cshtml *@

<!-- Create Employee Modal -->
<div class="modal fade" id="createEmployeeModal" tabindex="-1" aria-labelledby="createEmployeeLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="createEmployeeLabel">
                    <i class="bi bi-person-plus-fill me-2"></i> Új dolgozó létrehozása
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                        aria-label="Bezárás"></button>
            </div>

            <div class="modal-body">
                <form id="createEmployeeForm">

                    <h6 class="mb-3">Alap információk</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Vezetéknév</label>
                            <input type="text" class="form-control" name="LastName" maxlength="50">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Keresztnév</label>
                            <input type="text" class="form-control" name="FirstName" maxlength="50">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">E-mail</label>
                            <input type="email" class="form-control" name="Email" maxlength="100">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">E-mail 2</label>
                            <input type="email" class="form-control" name="Email2" maxlength="100">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Telefonszám</label>
                            <input type="text" class="form-control" name="PhoneNumber" maxlength="15">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Telefonszám 2</label>
                            <input type="text" class="form-control" name="PhoneNumber2" maxlength="15">
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Születési dátum</label>
                            <input type="date" class="form-control" name="DateOfBirth">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Belépés dátuma</label>
                            <input type="date" class="form-control" name="HireDate">
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="createEmployeeIsActive"
                                       name="IsActive" checked>
                                <label class="form-check-label" for="createEmployeeIsActive">Aktív</label>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4">

                    <h6 class="mb-3">Típus / Partner</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Dolgozó típusa *</label>
                            <select class="form-select" id="createWorkerTypeId" name="WorkerTypeId" required>
                                <option value="">Válasszon...</option>
                            </select>
                            <div class="form-text">INTERNAL esetén a Partner automatikusan nullázva lesz.</div>
                        </div>

                        <div class="col-md-6" id="createPartnerContainer" style="display:none;">
                            <label class="form-label">Partner (külsős esetén kötelező) *</label>
                            <select class="form-select" id="createPartnerId" name="PartnerId">
                                <option value="">Válasszon...</option>
                            </select>
                        </div>
                    </div>

                    <hr class="my-4">

                    <h6 class="mb-3">Munka / HR</h6>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Osztály</label>
                            <input type="number" class="form-control" name="DepartmentId" min="0" step="1">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Pozíció</label>
                            <select class="form-select" id="createJobTitleId" name="JobTitleId">
                                <option value="">Válasszon...</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Alap telephely</label>
                            <select class="form-select" id="createDefaultSiteId" name="DefaultSiteId">
                                <option value="">Válasszon...</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Napi munkaidő (óra)</label>
                            <input type="number" class="form-control" name="WorkingTime" min="0" max="99.99" step="0.01"
                                   value="8.00">
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Szerződéses</label>
                            <select class="form-select" name="IsContracted">
                                <option value="0" selected>Nem</option>
                                <option value="1">Igen</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Kilépés dátuma</label>
                            <input type="date" class="form-control" name="EmploymentEndDate">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Szabadság napok</label>
                            <input type="number" class="form-control" name="VacationDays" min="0" step="1">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Teljes szabadság napok</label>
                            <input type="number" class="form-control" name="FullVacationDays" min="0" step="1">
                        </div>
                    </div>

                    <hr class="my-4">

                    <h6 class="mb-3">Státuszok és telephelyek</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Státuszok</label>
                            <select class="form-select" id="createEmploymentStatusIds" name="StatusIds" multiple>
                                @* TomSelect tölti *@
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Telephelyek</label>
                            <select class="form-select" id="createSiteIds" name="SiteIds" multiple>
                                @* TomSelect tölti *@
                            </select>
                            <div class="form-text">Ajánlott szabály: külsős csak a saját partner telephelyeire.</div>
                        </div>
                    </div>

                    <hr class="my-4">

                    <h6 class="mb-3">Azonosítók</h6>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Adóazonosító jel</label>
                            <input type="text" class="form-control" name="TaxId" maxlength="10">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">TAJ</label>
                            <input type="text" class="form-control" name="TajNumber" maxlength="9">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Nemzetiség kód</label>
                            <input type="text" class="form-control" name="NationalityCode" maxlength="2"
                                   placeholder="HU">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Születési név</label>
                            <input type="text" class="form-control" name="BirthName" maxlength="100">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Anyja születési neve</label>
                            <input type="text" class="form-control" name="MotherBirthName" maxlength="100">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Születési hely</label>
                            <input type="text" class="form-control" name="BirthPlace" maxlength="100">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">FEOR kód</label>
                            <input type="text" class="form-control" name="FeorCode" maxlength="10">
                        </div>
                    </div>

                    <hr class="my-4">

                    <h6 class="mb-3">Címek</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Állandó lakcím</label>
                            <input type="text" class="form-control" name="PermanentAddress" maxlength="250">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Levelezési cím</label>
                            <input type="text" class="form-control" name="MailingAddress" maxlength="250">
                        </div>

                        <div class="col-md-12">
                            <label class="form-label">Cím (összefűzött)</label>
                            <input type="text" class="form-control" name="Address" maxlength="200">
                        </div>
                    </div>

                    <hr class="my-4">

                    <h6 class="mb-3">Pénzügy / Megjegyzések</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">IBAN</label>
                            <input type="text" class="form-control" name="BankAccountIban" maxlength="34">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Családi adatok</label>
                            <input type="text" class="form-control" name="FamilyData">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Komment 1</label>
                            <input type="text" class="form-control" name="Comment1">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Komment 2</label>
                            <input type="text" class="form-control" name="Comment2">
                        </div>
                    </div>

                </form>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Mégse</button>
                <button type="button" class="btn btn-primary" id="saveNewEmployeeBtn">Mentés</button>
            </div>

        </div>
    </div>
</div>


<!-- View Employee Modal -->
<div class="modal fade" id="viewEmployeeModal" tabindex="-1">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">

      <div class="modal-header bg-success text-white">
        <h5 class="modal-title" id="viewEmployeeModalTitle">Dolgozó</h5>

        <button id="editEmployeeBtn" type="button" class="btn btn-sm btn-outline-primary me-2" style="display:none;">
          <i class="bi bi-pencil"></i> Szerkesztés
        </button>

        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">

        <!-- TOP SUMMARY -->
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
          <div>
            <div class="fs-5 fw-semibold" id="ve_fullName">–</div>
            <div class="text-muted small">
              ID: <span id="ve_employeeId">–</span>
              <span class="mx-2">•</span>
              Aktív: <span id="ve_isActiveText">–</span>
            </div>
          </div>

          <div class="text-end">
            <span class="badge bg-light text-dark border" id="ve_workerTypeBadge">–</span>
            <span class="badge bg-light text-dark border" id="ve_partnerBadge" style="display:none;">–</span>
          </div>
        </div>

        <!-- NAV TABS -->
        <ul class="nav nav-tabs" id="ve_tabs" role="tablist">
          <li class="nav-item" role="presentation">
            <button class="nav-link active" id="ve-tab-basic" data-bs-toggle="tab" data-bs-target="#ve-basic" type="button" role="tab">
              Alap
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="ve-tab-work" data-bs-toggle="tab" data-bs-target="#ve-work" type="button" role="tab">
              Munkaviszony
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="ve-tab-status-sites" data-bs-toggle="tab" data-bs-target="#ve-status-sites" type="button" role="tab">
              Státuszok & telephelyek
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="ve-tab-ids" data-bs-toggle="tab" data-bs-target="#ve-ids" type="button" role="tab">
              Azonosítók
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="ve-tab-notes" data-bs-toggle="tab" data-bs-target="#ve-notes" type="button" role="tab">
              Megjegyzések
            </button>
          </li>
        </ul>

        <div class="tab-content pt-3">

          <!-- BASIC -->
          <div class="tab-pane fade show active" id="ve-basic" role="tabpanel" aria-labelledby="ve-tab-basic">
            <div class="row g-3">

              <div class="col-md-6">
                <label class="form-label">Email</label>
                <div class="form-control bg-light" id="ve_email">–</div>
                <small class="text-muted" id="ve_email2_wrap" style="display:none;">
                  Másodlagos: <span id="ve_email2"></span>
                </small>
              </div>

              <div class="col-md-6">
                <label class="form-label">Telefon</label>
                <div class="form-control bg-light" id="ve_phoneNumber">–</div>
                <small class="text-muted" id="ve_phone2_wrap" style="display:none;">
                  Másodlagos: <span id="ve_phoneNumber2"></span>
                </small>
              </div>

              <div class="col-md-4">
                <label class="form-label">Születési dátum</label>
                <div class="form-control bg-light" id="ve_dateOfBirth">–</div>
              </div>

              <div class="col-md-8">
                <label class="form-label">Cím</label>
                <div class="form-control bg-light" id="ve_address">–</div>
              </div>

              <div class="col-md-4">
                <label class="form-label">Belépés dátuma</label>
                <div class="form-control bg-light" id="ve_hireDate">–</div>
              </div>

              <div class="col-md-4">
                <label class="form-label">Kilépés dátuma</label>
                <div class="form-control bg-light" id="ve_employmentEndDate">–</div>
              </div>

              <div class="col-md-4">
                <label class="form-label">Osztály</label>
                <div class="form-control bg-light" id="ve_department">–</div>
              </div>

              <div class="col-md-12">
                <label class="form-label">Állandó lakcím</label>
                <div class="form-control bg-light" id="ve_permanentAddress">–</div>
              </div>

              <div class="col-md-12">
                <label class="form-label">Levelezési cím</label>
                <div class="form-control bg-light" id="ve_mailingAddress">–</div>
              </div>

              <div class="col-md-12">
                <label class="form-label">Bank IBAN</label>
                <div class="form-control bg-light" id="ve_bankAccountIban">–</div>
              </div>

            </div>
          </div>

          <!-- WORK -->
          <div class="tab-pane fade" id="ve-work" role="tabpanel" aria-labelledby="ve-tab-work">
            <div class="row g-3">

              <div class="col-md-4">
                <label class="form-label">Worker type</label>
                <div class="form-control bg-light" id="ve_workerTypeName">–</div>
              </div>

              <div class="col-md-4">
                <label class="form-label">Partner</label>
                <div class="form-control bg-light" id="ve_partnerName">–</div>
              </div>

              <div class="col-md-4">
                <label class="form-label">Munkakör</label>
                <div class="form-control bg-light" id="ve_jobTitleName">–</div>
              </div>

              <div class="col-md-6">
                <label class="form-label">Alap telephely</label>
                <div class="form-control bg-light" id="ve_defaultSiteName">–</div>
              </div>

              <div class="col-md-3">
                <label class="form-label">Napi munkaidő</label>
                <div class="form-control bg-light" id="ve_workingTime">–</div>
              </div>

              <div class="col-md-3">
                <label class="form-label">Szerződéses</label>
                <div class="form-control bg-light" id="ve_isContracted">–</div>
              </div>

              <div class="col-md-6">
                <label class="form-label">Családi adatok</label>
                <div class="form-control bg-light" id="ve_familyData">–</div>
              </div>

              <div class="col-md-3">
                <label class="form-label">Szabadság napok</label>
                <div class="form-control bg-light" id="ve_vacationDays">–</div>
              </div>

              <div class="col-md-3">
                <label class="form-label">Teljes szabadság</label>
                <div class="form-control bg-light" id="ve_fullVacationDays">–</div>
              </div>

            </div>
          </div>

          <!-- STATUS + SITES -->
          <div class="tab-pane fade" id="ve-status-sites" role="tabpanel" aria-labelledby="ve-tab-status-sites">

            <div class="row g-4">

              <div class="col-lg-6">
                <div class="d-flex align-items-center justify-content-between mb-2">
                  <h6 class="mb-0">Státuszok</h6>
                  <small class="text-muted" id="ve_statusCount">–</small>
                </div>
                <div class="table-responsive">
                  <table class="table table-sm align-middle">
                    <thead>
                      <tr>
                        <th>Státusz</th>
                        <th class="text-nowrap">Assigned</th>
                      </tr>
                    </thead>
                    <tbody id="ve_statusRows">
                      <tr><td colspan="2" class="text-muted">–</td></tr>
                    </tbody>
                  </table>
                </div>
              </div>

              <div class="col-lg-6">
                <div class="d-flex align-items-center justify-content-between mb-2">
                  <h6 class="mb-0">Telephelyek</h6>
                  <small class="text-muted" id="ve_siteCount">–</small>
                </div>
                <div class="table-responsive">
                  <table class="table table-sm align-middle">
                    <thead>
                      <tr>
                        <th>Telephely</th>
                        <th class="text-nowrap">Alap</th>
                      </tr>
                    </thead>
                    <tbody id="ve_siteRows">
                      <tr><td colspan="2" class="text-muted">–</td></tr>
                    </tbody>
                  </table>
                </div>
              </div>

            </div>

          </div>

          <!-- IDS -->
          <div class="tab-pane fade" id="ve-ids" role="tabpanel" aria-labelledby="ve-tab-ids">
            <div class="row g-3">

              <div class="col-md-4">
                <label class="form-label">Adóazonosító (TaxId)</label>
                <div class="form-control bg-light" id="ve_taxId">–</div>
              </div>

              <div class="col-md-4">
                <label class="form-label">TAJ</label>
                <div class="form-control bg-light" id="ve_tajNumber">–</div>
              </div>

              <div class="col-md-4">
                <label class="form-label">FEOR</label>
                <div class="form-control bg-light" id="ve_feorCode">–</div>
              </div>

              <div class="col-md-6">
                <label class="form-label">Születési név</label>
                <div class="form-control bg-light" id="ve_birthName">–</div>
              </div>

              <div class="col-md-6">
                <label class="form-label">Anyja neve</label>
                <div class="form-control bg-light" id="ve_motherBirthName">–</div>
              </div>

              <div class="col-md-6">
                <label class="form-label">Születési hely</label>
                <div class="form-control bg-light" id="ve_birthPlace">–</div>
              </div>

              <div class="col-md-6">
                <label class="form-label">Állampolgárság kód</label>
                <div class="form-control bg-light" id="ve_nationalityCode">–</div>
              </div>

            </div>
          </div>

          <!-- NOTES -->
          <div class="tab-pane fade" id="ve-notes" role="tabpanel" aria-labelledby="ve-tab-notes">
            <div class="row g-3">

              <div class="col-md-6">
                <label class="form-label">Megjegyzés 1</label>
                <div class="form-control bg-light" id="ve_comment1" style="min-height: 80px; white-space: pre-wrap;">–</div>
              </div>

              <div class="col-md-6">
                <label class="form-label">Megjegyzés 2</label>
                <div class="form-control bg-light" id="ve_comment2" style="min-height: 80px; white-space: pre-wrap;">–</div>
              </div>

            </div>
          </div>

        </div>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Bezár</button>
      </div>

    </div>
  </div>
</div>

<!-- Edit Employee Modal -->
<div class="modal fade" id="editEmployeeModal" tabindex="-1" aria-labelledby="editEmployeeLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="editEmployeeLabel">
                    <i class="bi bi-pencil-square me-2"></i> Dolgozó szerkesztése
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                        aria-label="Bezárás"></button>
            </div>

            <div class="modal-body">
                <form id="editEmployeeForm">
                    <input type="hidden" id="editEmployeeId" name="EmployeeId" />

                    <h6 class="mb-3">Alap információk</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Vezetéknév</label>
                            <input type="text" class="form-control" id="editLastName" name="LastName" maxlength="50">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Keresztnév</label>
                            <input type="text" class="form-control" id="editFirstName" name="FirstName" maxlength="50">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">E-mail</label>
                            <input type="email" class="form-control" id="editEmail" name="Email" maxlength="100">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">E-mail 2</label>
                            <input type="email" class="form-control" id="editEmail2" name="Email2" maxlength="100">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Telefonszám</label>
                            <input type="text" class="form-control" id="editPhoneNumber" name="PhoneNumber"
                                   maxlength="15">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Telefonszám 2</label>
                            <input type="text" class="form-control" id="editPhoneNumber2" name="PhoneNumber2"
                                   maxlength="15">
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Születési dátum</label>
                            <input type="date" class="form-control" id="editDateOfBirth" name="DateOfBirth">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Belépés dátuma</label>
                            <input type="date" class="form-control" id="editHireDate" name="HireDate">
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="editEmployeeIsActive"
                                       name="IsActive">
                                <label class="form-check-label" for="editEmployeeIsActive">Aktív</label>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4">

                    <h6 class="mb-3">Típus / Partner</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Dolgozó típusa *</label>
                            <select class="form-select" id="editWorkerTypeId" name="WorkerTypeId" required>
                                <option value="">Válasszon...</option>
                            </select>
                        </div>

                        <div class="col-md-6" id="editPartnerContainer" style="display:none;">
