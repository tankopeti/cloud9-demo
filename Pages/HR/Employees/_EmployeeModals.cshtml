<!-- Employee History Modal -->
<div class="modal fade" id="employeeHistoryModal" tabindex="-1" aria-labelledby="employeeHistoryModalLabel"
     aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">

      <div class="modal-header bg-success text-white">
        <h5 class="modal-title" id="employeeHistoryModalLabel">
          <i class="bi bi-clock-history me-2"></i>
          <span id="history-employee-name"></span> – Történet
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                aria-label="Bezárás"></button>
      </div>

      <div class="modal-body">

        <!-- Mini CSS csak ehhez a modalhoz -->
        <style>
          .emp-timeline {
            position: relative;
            margin: 0;
            padding: 0.25rem 0 0.25rem 0;
            list-style: none;
          }
          .emp-timeline::before {
            content: "";
            position: absolute;
            top: 0.5rem;
            bottom: 0.5rem;
            left: 18px;
            width: 2px;
            background: rgba(0,0,0,.12);
          }
          .emp-timeline-item {
            position: relative;
            display: grid;
            grid-template-columns: 42px 1fr;
            gap: .75rem;
            padding: .5rem 0;
          }
          .emp-timeline-dot {
            width: 36px;
            height: 36px;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: #fff;
            border: 2px solid rgba(0,0,0,.12);
            z-index: 2;
            margin-left: 0px;
          }
          .emp-timeline-meta {
            font-size: .85rem;
          }
          .emp-timeline-card {
            border: 1px solid rgba(0,0,0,.12);
            border-radius: .75rem;
            padding: .75rem .9rem;
            background: #fff;
          }
          .emp-timeline-title {
            font-weight: 600;
            margin: 0;
            display: flex;
            align-items: center;
            gap: .5rem;
            flex-wrap: wrap;
          }
          .emp-timeline-changes {
            margin-top: .5rem;
            white-space: pre-line;
          }
          .emp-timeline-changes code {
            background: rgba(0,0,0,.04);
            padding: .1rem .35rem;
            border-radius: .35rem;
          }
        </style>

        <div id="employee-history-loading" class="text-center py-4">
          <div class="spinner-border" role="status" aria-hidden="true"></div>
          <p class="mt-3 mb-0">Történet betöltése...</p>
        </div>

        <div id="employee-history-content" class="d-none">
          <div id="employee-history-empty" class="text-muted text-center py-4 d-none">
            <i class="bi bi-inbox display-6"></i>
            <p class="mt-3 mb-0">Nincs rögzített változás ehhez a dolgozóhoz.</p>
          </div>

          <!-- Ide rendereli a JS a timeline-t -->
          <div id="employee-history-list"></div>
        </div>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Bezárás</button>
      </div>

    </div>
  </div>
</div>


