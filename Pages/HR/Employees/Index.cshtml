@page
@model Cloud9_2.Pages.HR.Employees.IndexModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Dolgozók";
}

@await Html.PartialAsync("_HRSidebar")

<div class="right-content">
    <div class="page-header-fixed-top">

        <div class="d-flex justify-content-between align-items-center mb-2">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-body-tertiary rounded-3 p-2 mb-0">
                    <li class="breadcrumb-item"><a href="../../">Főoldal</a></li>
                    <li class="breadcrumb-item"><a href="../">HR Dashboard</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Dolgozók</li>
                    <li class="breadcrumb-item active" aria-current="page">
                        @Model.Employees.Count of @Model.TotalRecords dolgozó@(Model.TotalRecords != 1 ? "k" : "")
                        (Oldal @Model.CurrentPage / @Model.TotalPages)
                    </li>
                </ol>
            </nav>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">

            <div class="d-flex align-items-center gap-2">
                <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#createEmployeeModal">
                    + Új dolgozó
                </button>

                <button class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#advancedEmployeeFilterModal">
                    <i class="bi bi-funnel me-1"></i> Összetett szűrés
                </button>

                <button id="exportEmployeesExcelBtn" class="btn btn-outline-success">
                    <i class="bi bi-file-earmark-excel me-1"></i>
                    Export Excel
                </button>
            </div>

            <div class="d-flex align-items-center gap-2">
                <form id="employeeSearchForm" method="get" asp-page="./Index" class="input-group input-group-sm" style="width: 280px;">
                    <input type="text"
                           class="form-control"
                           placeholder="Dolgozók keresése..."
                           id="employeeSearchInput"
                           name="SearchTerm"
                           value="@Model.SearchTerm">

                    <input type="hidden" name="pageSize" value="@Model.PageSize" />

                    <button class="btn btn-outline-secondary" type="submit">
                        <i class="bi bi-search"></i>
                    </button>
                </form>

                <div class="dropdown">
                    <button id="employeeQuickFilterToggle"
                            class="btn btn-outline-secondary btn-sm dropdown-toggle"
                            type="button"
                            data-bs-toggle="dropdown">
                        <i class="bi bi-funnel me-1"></i>Szűrő
                    </button>

                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="#" data-filter="all">Minden dolgozó</a></li>
                        <li><a class="dropdown-item" href="#" data-filter="active">Aktív dolgozók</a></li>
                        <li><a class="dropdown-item" href="#" data-filter="internal">Belsős</a></li>
                        <li><a class="dropdown-item" href="#" data-filter="external">Külsős</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="table-dynamic-height">
            <table class="table table-striped table-hover mb-0">
                <thead class="sticky-top custom-thead table-blur">
                    <tr>
                        <th>Név</th>
                        <th>Email</th>
                        <th>Telefon</th>
                        <th>Típus</th>
                        <th>Partner</th>
                        <th>Pozíció</th>
                        <th>Státusz(ok)</th>
                        <th>Telephely(ek)</th>
                        <th>Aktív</th>
                        <th class="text-center">Műveletek</th>
                    </tr>
                </thead>

                <tbody id="employeesTableBody">
                    <tr>
                        <td colspan="10" class="text-center py-5 text-muted">
                            Betöltés...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div id="loadMoreEmployeesContainer" class="text-center py-2">
            <button id="loadMoreEmployeesBtn" class="btn btn-outline-primary btn-sm">
                Több betöltése
            </button>
        </div>
    </div>

    <!-- Include Modals -->
    @await Html.PartialAsync("_EmployeeModals")

    @section Scripts {
    <script src="~/js/HR/employeesIndex.js"></script>
    <script src="~/js/HR/employeesCreate.js"></script>
    <script src="~/js/HR/employeesView.js"></script>
    <script src="~/js/HR/employeesEdit.js"></script>
    <script src="/js/HR/employee-delete.js"></script>
    <script src="/js/HR/employee-advanced-filter.js"></script>
    <script src="/js/HR/employee-history.js"></script>
    <script src="/js/HR/employee-sites.js"></script>
    <script src="/js/HR/employee-files.js"></script>
}

</div>