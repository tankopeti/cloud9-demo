@using Cloud9_2.Models
@inject IHttpClientFactory HttpClientFactory

@{
  var priorities = ViewData["Priorities"] as List<TaskPriorityPM> ?? new();
  var statuses = ViewData["Statuses"] as List<TaskStatusPM> ?? new();
  var types = ViewData["Types"] as List<TaskTypePM> ?? new();
  var partners = ViewData["Partners"] as List<Partner> ?? new();
  var sites = ViewData["Sites"] as List<Site> ?? new();
  var contacts = ViewData["Contacts"] as List<Contact> ?? new();
  var quotes = ViewData["Quotes"] as List<Quote> ?? new();
  var orders = ViewData["Orders"] as List<Order> ?? new();
  var communications = ViewData["Communications"] as List<CustomerCommunication> ?? new();
  var users = ViewData["Users"] as List<ApplicationUser> ?? new();
}

<!-- ====================== 1. ÚJ INTÉZKEDÉS MODAL ====================== -->
<div class="modal fade" id="newTaskModal" data-display-type="2" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl">
    <div class="modal-content shadow-lg border-0 overflow-hidden d-flex flex-column task-view-modal-content">

      <form id="createTaskForm" asp-page-handler="Create" method="post">
        @Html.AntiForgeryToken()

        <!-- HEADER -->
        <div class="modal-header py-2 bg-success text-white">
          <h5 class="modal-title fs-5 fw-semibold">
            <i class="bi bi-plus-circle me-2"></i> Új intézkedés
          </h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>

        <!-- BODY -->
        <div class="modal-body py-4">

          <!-- Alap adatok -->
          <div class="row g-3">

            <!-- Telephely -->
            <div class="col-md-6">
              <label class="form-label">Telephely <span class="text-danger">*</span></label>
              <select name="SiteId" id="SiteId" class="form-select" required></select>
            </div>

            <!-- Kapcsolt személy -->
            <div class="col-md-6">
              <label class="form-label">Kapcsolt személy</label>
              <select id="RelatedEmployeeId" name="RelatedEmployeeId" class="form-select">
                <option value="">-- Előbb válassz telephelyet --</option>
              </select>
              <div class="form-text">
                A kiválasztott telephelyhez kapcsolt dolgozók közül választhatsz.
              </div>
            </div>

            <!-- Kapcsolt partner -->
            <div class="col-md-6">
              <label class="form-label">
                Kapcsolt partner <span class="text-muted">(szállító / közvetítő)</span>
              </label>
              <select class="form-select" name="RelatedPartnerId" id="RelatedPartnerId">
                <option value="">-- Nincs --</option>
                @foreach (var p in partners)
                {
                  <option value="@p.PartnerId">@p.Name</option>
                }
              </select>
              <div class="form-text">
                Opcionális: válaszd ki, ha a feladathoz külsős szállítót/közvetítőt veszel igénybe.
              </div>
            </div>

            <!-- Feladat típusa -->
            <div class="col-md-6">
              <label class="form-label">Feladat típusa <span class="text-danger">*</span></label>
              <select class="form-select" name="TaskTypePMId" id="TaskTypePMId" required>
                <option value="">-- Válasszon --</option>
              </select>
            </div>

            <!-- Prioritás -->
            <div class="col-md-6">
              <label class="form-label">Prioritás</label>
              <select class="form-select" name="TaskPriorityPMId">
                @foreach (var p in priorities)
                {
                  <option value="@p.TaskPriorityPMId" selected="@(p.TaskPriorityPMId == 2)">
                    @p.Name
                  </option>
                }
              </select>
            </div>

          </div>

          <!-- Tárgy -->
          <div class="mt-3">
            <label class="form-label">Tárgy <span class="text-danger">*</span></label>
            <input type="text" class="form-control" name="Title" required maxlength="100" />
          </div>

          <!-- Leírás -->
          <div class="mt-3">
            <label class="form-label">Bővebb leírás</label>
            <textarea class="form-control" name="Description" rows="3"></textarea>
          </div>

          <!-- Felelős / Státusz -->
          <div class="row g-3 mt-3">

            <div class="col-md-6">
              <label class="form-label">Felelős</label>
              <select name="AssignedToId" id="AssignedToId" class="form-select">
                <option value="">-- Válasszon --</option>
              </select>
            </div>

            <div class="col-md-6">
              <label class="form-label">Státusz</label>
              <select class="form-select" name="TaskStatusPMId" id="TaskStatusPMId" required>
                <option value="">-- Válasszon --</option>
              </select>
            </div>

          </div>

          <!-- Kommunikáció -->
          <div class="row g-3 mt-3">

            <div class="col-md-6">
              <label class="form-label">Kommunikáció mód</label>
              <select class="form-select" name="TaskPMcomMethodID" id="TaskPMcomMethodID">
                <option value="">-- Válasszon --</option>
              </select>
            </div>

            <div class="col-md-6">
              <label class="form-label">Név / elérhetőség / részletek</label>
              <input type="text" class="form-control" name="CommunicationDescription" />
            </div>

            <div class="col-md-6">
              <label class="form-label">Beütemezve (dátum)</label>
              <input type="date" class="form-control" name="ScheduledDate" />
            </div>

            <div class="col-md-6">
              <label class="form-label">Beütemezve (idő)</label>
              <input type="time" class="form-control" name="ScheduledTime" step="60" />
            </div>

          </div>

        </div>

        <!-- FOOTER -->
        <div class="modal-footer py-3">
          <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">
            Mégse
          </button>

          <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-check2 me-1"></i> Létrehozás
          </button>
        </div>

      </form>
    </div>
  </div>
</div>



<!-- TASK DOCUMENTS MODAL (UPLOAD TO /Users/tp/Projects/fileok) -->
<div class="modal fade" id="taskDocumentsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content shadow-lg border-0 overflow-hidden d-flex flex-column task-view-modal-content">

      <div class="modal-header py-2 bg-primary text-white">
        <h5 class="modal-title fs-5 fw-semibold">
          <i class="bi bi-paperclip me-2"></i> Feladat fájlok
          <span class="badge bg-light text-primary ms-2" id="taskDocsCount">0</span>
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Bezárás"></button>
      </div>

      <div class="modal-body py-3">
        <input type="hidden" id="taskDocsTaskId" value="" />

        <div class="d-flex gap-2 align-items-center mb-3">
          <button type="button" id="taskDocsAddBtn" class="btn btn-outline-primary">
            <i class="bi bi-upload me-1"></i> Fájl hozzáadása
          </button>
          <input type="file" id="taskDocsFileInput" class="d-none" />

          <input type="text" id="taskDocsNote" class="form-control" placeholder="Megjegyzés (opcionális)" />
        </div>

        <div id="taskDocsList" class="border rounded p-3 bg-white" style="min-height:120px;">
          <div class="text-muted small">Még nincs csatolt fájl a feladathoz.</div>
        </div>
      </div>

      <div class="modal-footer py-2">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Bezárás</button>
      </div>

    </div>
  </div>
</div>

