<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cloud9.2</title>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/signalr.min.js"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <style>
            :root {
                --app-bg: #f5f7fb;
                --sidebar-bg: #0f172a;
                --sidebar-bg-2: #111827;
                --sidebar-text: #cbd5e1;
                --sidebar-active-bg: rgba(255, 255, 255, .12);
                --sidebar-hover-bg: rgba(255, 255, 255, .06);
                --sidebar-title: #94a3b8;
                --topbar-bg: rgba(255, 255, 255, .92);
                --card-bg: #ffffff;
                --border-soft: #e5e7eb;
                --text-main: #111827;
                --text-muted: #6b7280;
                --primary: #635bff;
                --shadow-soft: 0 10px 30px rgba(15, 23, 42, 0.08);
                --radius-lg: 20px;
                --radius-md: 14px;
                --sidebar-width: 330px;
                --topbar-height: 76px;
            }

            html,
            body {
                height: 100%;
                background: var(--app-bg);
                color: var(--text-main);
            }

            body {
                margin: 0;
                font-family: Inter, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            }

            .app-shell {
                min-height: 100vh;
            }

            .app-sidebar {
                position: fixed;
                inset: 0 auto 0 0;
                width: var(--sidebar-width);
                background: linear-gradient(180deg, var(--sidebar-bg) 0%, var(--sidebar-bg-2) 100%);
                color: white;
                z-index: 1040;
                overflow-y: auto;
                padding: 1.5rem 1.25rem;
                box-shadow: 8px 0 30px rgba(2, 6, 23, 0.25);
            }

            .brand-box {
                display: flex;
                align-items: center;
                gap: 1rem;
                padding-bottom: 1.25rem;
                margin-bottom: 1.25rem;
                border-bottom: 1px solid rgba(255, 255, 255, .08);
            }

            .brand-logo {
                width: 52px;
                height: 52px;
                border-radius: 16px;
                background: linear-gradient(135deg, #635bff, #8b5cf6);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.75rem;
                font-weight: 700;
                color: white;
            }

            .brand-title {
                font-size: 1.9rem;
                font-weight: 700;
                line-height: 1.1;
            }

            .brand-subtitle {
                font-size: 1rem;
                color: var(--sidebar-title);
                margin-top: .2rem;
            }

            .sidebar-group-title {
                font-size: .8rem;
                font-weight: 800;
                letter-spacing: .08em;
                text-transform: uppercase;
                color: var(--sidebar-title);
                margin: 1.2rem 0 .8rem;
                padding: 0 .75rem;
            }

            .sidebar-menu,
            .sidebar-submenu {
                list-style: none;
                margin: 0;
                padding: 0;
            }

            .sidebar-item {
                margin-bottom: .4rem;
            }

            .sidebar-link,
            .sidebar-collapse {
                width: 100%;
                border: 0;
                background: transparent;
                color: var(--sidebar-text);
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: .9rem;
                border-radius: 16px;
                padding: 1rem 1rem;
                transition: .2s ease;
                font-size: 1rem;
                font-weight: 500;
            }

            .sidebar-link:hover,
            .sidebar-collapse:hover {
                background: var(--sidebar-hover-bg);
                color: white;
            }

            .sidebar-link.active {
                background: var(--sidebar-active-bg);
                color: white;
            }

            .sidebar-link i,
            .sidebar-collapse i {
                font-size: 1.15rem;
                width: 22px;
            }

            .sidebar-submenu {
                margin-top: .4rem;
                padding-left: 0;
            }

            .sidebar-submenu .sidebar-link {
                padding-left: 3rem;
                font-size: .98rem;
            }

            .app-main {
                margin-left: var(--sidebar-width);
                min-height: 100vh;
            }

            .app-topbar {
                height: var(--topbar-height);
                position: sticky;
                top: 0;
                z-index: 1030;
                background: var(--topbar-bg);
                backdrop-filter: blur(12px);
                border-bottom: 1px solid var(--border-soft);
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 1.75rem;
            }

            .topbar-title {
                font-size: 1.15rem;
                font-weight: 600;
                color: #6b7280;
            }

            .topbar-right {
                display: flex;
                align-items: center;
                gap: 1rem;
            }

            .topbar-search {
                position: relative;
                min-width: 345px;
            }

            .topbar-search i {
                position: absolute;
                left: 1rem;
                top: 50%;
                transform: translateY(-50%);
                color: #9ca3af;
                font-size: 1.15rem;
            }

            .topbar-search input {
                width: 100%;
                border: 1px solid var(--border-soft);
                background: #fff;
                border-radius: 18px;
                padding: 1rem 1rem 1rem 2.9rem;
                font-size: 1rem;
                outline: none;
            }

            .topbar-search input:focus {
                border-color: #c7d2fe;
                box-shadow: 0 0 0 4px rgba(99, 91, 255, 0.08);
            }

            .account-btn {
                border: 1px solid var(--border-soft);
                background: white;
                border-radius: 18px;
                padding: .85rem 1rem;
                display: flex;
                align-items: center;
                gap: .85rem;
                min-width: 175px;
            }

            .avatar {
                width: 42px;
                height: 42px;
                border-radius: 50%;
                background: linear-gradient(135deg, #635bff, #8b5cf6);
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-size: 1.15rem;
                flex-shrink: 0;
            }

            .account-text {
                line-height: 1.15;
                text-align: left;
            }

            .account-text .name {
                font-size: 1rem;
                font-weight: 600;
                color: #111827;
            }

            .account-text .sub {
                font-size: .95rem;
                color: #6b7280;
            }

            .page-wrap {
                padding: 1.75rem;
            }

            .page-card {
                background: var(--card-bg);
                border: 1px solid rgba(229, 231, 235, .85);
                border-radius: 24px;
                box-shadow: var(--shadow-soft);
                padding: 1.75rem;
            }

            .dropdown-menu {
                border: 1px solid var(--border-soft);
                border-radius: 16px;
                box-shadow: 0 20px 40px rgba(15, 23, 42, .12);
                padding: .5rem;
            }

            .dropdown-item {
                border-radius: 10px;
                padding: .7rem .9rem;
            }

            .mobile-toggle {
                display: none;
                width: 42px;
                height: 42px;
                border-radius: 12px;
                border: 1px solid var(--border-soft);
                background: white;
                align-items: center;
                justify-content: center;
            }

            @@media (max-width: 991.98px) {
                .app-sidebar {
                    transform: translateX(-100%);
                    transition: transform .25s ease;
                }

                .app-sidebar.show {
                    transform: translateX(0);
                }

                .app-main {
                    margin-left: 0;
                }

                .mobile-toggle {
                    display: inline-flex;
                }

                .topbar-search {
                    display: none;
                }
            }
    </style>
</head>

<body>
    <div class="app-shell">

@{
    var path = Context.Request.Path;

    var isUsersSection = path.StartsWithSegments("/Admin/Users")
        || path.StartsWithSegments("/Admin/LoginLog")
        || path.StartsWithSegments("/Admin/ActiveUsers")
        || path.StartsWithSegments("/Admin/Roles")
        || path.StartsWithSegments("/Admin/ManageRoles");

    var isMailSection = path.StartsWithSegments("/Admin/Email");

    var isSettingsSection = path.StartsWithSegments("/Admin/Settings");
}

        <aside class="app-sidebar" id="appSidebar">
<a href="/Admin/Index" class="brand-box text-decoration-none">
    <div class="brand-logo">C9</div>
    <div>
        <div class="brand-title text-white">Cloud9.2</div>
        <div class="brand-subtitle">Admin dashboard</div>
    </div>
</a>

            <div class="sidebar-group-title">Felügyelet</div>

            <ul class="sidebar-menu">
<li class="sidebar-item">
    <button class="sidebar-collapse" type="button" data-bs-toggle="collapse" data-bs-target="#usersMenu"
            aria-expanded="@(isUsersSection ? "true" : "false")">
        <i class="bi bi-people"></i>
        <span>Users</span>
        <i class="bi bi-chevron-down ms-auto"></i>
    </button>

    <ul class="sidebar-submenu collapse @(isUsersSection ? "show" : "")" id="usersMenu">
        <li>
            <a class="sidebar-link @(Context.Request.Path.StartsWithSegments("/Admin/Users") ? "active" : "")"
               href="/Admin/Users/">
                <i class="bi bi-person"></i>
                <span>Userek</span>
            </a>
        </li>
        <li>
            <a class="sidebar-link @(Context.Request.Path.StartsWithSegments("/Admin/LoginLog") ? "active" : "")"
               href="/Admin/LoginLog/LoginLog">
                <i class="bi bi-box-arrow-in-right"></i>
                <span>Loginok</span>
            </a>
        </li>
        <li>
            <a class="sidebar-link @(Context.Request.Path.StartsWithSegments("/Admin/ActiveUsers") ? "active" : "")"
               href="/Admin/ActiveUsers/ActiveUsers">
                <i class="bi bi-broadcast"></i>
                <span>Aktív userek</span>
            </a>
        </li>
        <li>
            <a class="sidebar-link @(Context.Request.Path.StartsWithSegments("/Admin/Roles") ? "active" : "")"
               href="/Admin/Roles/">
                <i class="bi bi-shield-lock"></i>
                <span>Role-ok</span>
            </a>
        </li>
        <li>
            <a class="sidebar-link @(Context.Request.Path.StartsWithSegments("/Admin/ManageRoles") ? "active" : "")"
               href="/Admin/ManageRoles/ManageRoles">
                <i class="bi bi-diagram-3"></i>
                <span>User-role</span>
            </a>
        </li>
    </ul>
</li>

<li class="sidebar-item">
    <button class="sidebar-collapse" type="button" data-bs-toggle="collapse" data-bs-target="#mailMenu"
            aria-expanded="@(isMailSection ? "true" : "false")">
        <i class="bi bi-envelope"></i>
        <span>Mail beállítások</span>
        <i class="bi bi-chevron-down ms-auto"></i>
    </button>

    <ul class="sidebar-submenu collapse @(isMailSection ? "show" : "")" id="mailMenu">
        <li>
            <a class="sidebar-link @(path.StartsWithSegments("/Admin/Email") && path.Value == "/Admin/Email" || path.Value == "/Admin/Email/" ? "active" : "")"
               href="/Admin/Email/">
                <i class="bi bi-file-earmark-text"></i>
                <span>Sablonok</span>
            </a>
        </li>

        <li>
            <a class="sidebar-link @(Context.Request.Path.StartsWithSegments("/Admin/Email/Variables") ? "active" : "")"
               href="/Admin/Email/Variables">
                <i class="bi bi-braces"></i>
                <span>Template változók</span>
            </a>
        </li>

        <li>
            <a class="sidebar-link @(Context.Request.Path.StartsWithSegments("/Admin/Email/Queue") ? "active" : "")"
               href="/Admin/Email/Queue">
                <i class="bi bi-list-task"></i>
                <span>Queue</span>
            </a>
        </li>

        <li>
            <a class="sidebar-link @(Context.Request.Path.StartsWithSegments("/Admin/Email/Logs") ? "active" : "")"
               href="/Admin/Email/Logs">
                <i class="bi bi-journal-text"></i>
                <span>Logok</span>
            </a>
        </li>
    </ul>
</li>

<li class="sidebar-item">
    <button class="sidebar-collapse" type="button" data-bs-toggle="collapse"
            data-bs-target="#settingsMenu" aria-expanded="@(isSettingsSection ? "true" : "false")">
        <i class="bi bi-sliders"></i>
        <span>Program beállítások</span>
        <i class="bi bi-chevron-down ms-auto"></i>
    </button>
    <ul class="sidebar-submenu collapse @(isSettingsSection ? "show" : "")" id="settingsMenu">
        <li>
            <a class="sidebar-link @(Context.Request.Path.StartsWithSegments("/Admin/Settings/Sql") ? "active" : "")"
               href="/Admin/Settings/Sql/SQLsettings">
                <i class="bi bi-database-gear"></i>
                <span>SQL beállítások</span>
            </a>
        </li>
    </ul>
</li>
            </ul>
        </aside>

        <div class="app-main">
            <header class="app-topbar">
                <div class="d-flex align-items-center gap-3">
                    <button class="mobile-toggle" type="button" id="mobileMenuToggle">
                        <i class="bi bi-list"></i>
                    </button>
                    <div class="topbar-title">Modern admin felület</div>
                </div>

                <div class="topbar-right">
                    <div class="topbar-search">
                        <i class="bi bi-search"></i>
                        <input type="text" placeholder="Keresés..." />
                    </div>

                    <div class="dropdown">
                        <button class="account-btn dropdown-toggle" type="button" data-bs-toggle="dropdown"
                                aria-expanded="false">
                            <div class="avatar">
                                <i class="bi bi-person"></i>
                            </div>
                            <div class="account-text">
                                <div class="name">Fiók</div>
                                <div class="sub">Beállítások</div>
                            </div>
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end">
                            @if (User.IsInRole("SuperAdmin"))
                            {
                                <li>
                                    <a class="dropdown-item" href="@Url.Page("/Admin/Index")">
                                        <i class="bi bi-speedometer2 me-2"></i>Admin
                                    </a>
                                </li>
                            }
                            <li>
                                <button class="dropdown-item" data-bs-toggle="modal"
                                        data-bs-target="#userSettingsModal">
                                    <i class="bi bi-gear me-2"></i>Beállítások
                                </button>
                            </li>
                            <li>
                                <hr class="dropdown-divider" />
                            </li>
                            <li>
                                <button class="dropdown-item text-danger" data-bs-toggle="modal"
                                        data-bs-target="#authModal">
                                    <i class="bi bi-box-arrow-right me-2"></i>Kilépés
                                </button>
                            </li>
                        </ul>
                    </div>
                </div>
            </header>

            <main class="page-wrap">
                <div class="page-card">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    @await Html.PartialAsync("_AuthModal")
    @await Html.PartialAsync("_UserSettingsModal")

    @await RenderSectionAsync("Scripts", required: false)

    <script>
            document.getElementById("mobileMenuToggle")?.addEventListener("click", function () {
                document.getElementById("appSidebar")?.classList.toggle("show");
            });
    </script>
</body>

</html>