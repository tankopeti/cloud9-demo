@page
@model Cloud9_2.Pages.Admin.Email.IndexModel
@{
    Layout = "/Pages/Admin/_Layout.cshtml";
    ViewData["Title"] = "Email sablonok";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1 fw-bold">Email sablonok</h1>
        <p class="text-muted mb-0">Sablonok kezelése</p>
    </div>

    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#templateModal" onclick="openCreateModal()">
        <i class="bi bi-plus-circle me-1"></i>Új sablon
    </button>
</div>

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-6">
                <input type="text" id="searchInput" class="form-control" placeholder="Keresés név, tárgy, leírás alapján...">
            </div>
            <div class="col-md-3">
                <select id="activeFilter" class="form-select">
                    <option value="">Összes</option>
                    <option value="true">Aktív</option>
                    <option value="false">Inaktív</option>
                </select>
            </div>
            <div class="col-md-3">
                <button class="btn btn-outline-secondary w-100" onclick="loadTemplates()">
                    <i class="bi bi-search me-1"></i>Szűrés
                </button>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Név</th>
                        <th>Tárgy</th>
                        <th>Leírás</th>
                        <th>Aktív</th>
                        <th class="text-end">Műveletek</th>
                    </tr>
                </thead>
                <tbody id="templatesTableBody">
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">Betöltés...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="templateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title" id="templateModalTitle">Új sablon</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form id="templateForm">
                    <input type="hidden" id="templateId">

                    <div class="mb-3">
                        <label class="form-label">Név</label>
                        <input type="text" id="templateName" class="form-control" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tárgy</label>
                        <input type="text" id="templateSubject" class="form-control" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Leírás</label>
                        <input type="text" id="templateDescription" class="form-control">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Törzs</label>
                        <textarea id="templateBody" class="form-control" rows="10" required></textarea>
                    </div>

                    <div class="form-check">
                        <input type="checkbox" id="templateIsActive" class="form-check-input" checked>
                        <label class="form-check-label" for="templateIsActive">Aktív</label>
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Mégse</button>
                <button class="btn btn-primary" onclick="saveTemplate()">Mentés</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let templateModal;

    document.addEventListener('DOMContentLoaded', async function () {
        templateModal = new bootstrap.Modal(document.getElementById('templateModal'));
        await loadTemplates();
    });

    async function loadTemplates() {
        const search = document.getElementById('searchInput').value.trim();
        const isActive = document.getElementById('activeFilter').value;

        const params = new URLSearchParams();
        if (search) params.append('search', search);
        if (isActive !== '') params.append('isActive', isActive);

        const response = await fetch(`/api/Email/templates?${params.toString()}`);
        if (!response.ok) {
            alert('Nem sikerült betölteni a sablonokat.');
            return;
        }

        const data = await response.json();
        const tbody = document.getElementById('templatesTableBody');

        if (!data || data.length === 0) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">Nincs találat.</td>
                </tr>`;
            return;
        }

        tbody.innerHTML = data.map(item => `
            <tr>
                <td class="fw-semibold">${escapeHtml(item.name)}</td>
                <td>${escapeHtml(item.subject ?? '')}</td>
                <td>${escapeHtml(item.description ?? '')}</td>
                <td>
                    ${item.isActive
                        ? '<span class="badge bg-success">Igen</span>'
                        : '<span class="badge bg-secondary">Nem</span>'}
                </td>
                <td class="text-end">
                    <div class="btn-group btn-group-sm">
                        <button class="btn btn-outline-info" onclick="openDetailsModal(${item.id})">
                            <i class="bi bi-eye"></i>
                        </button>
                        <button class="btn btn-outline-primary" onclick="openEditModal(${item.id})">
                            <i class="bi bi-pencil-square"></i>
                        </button>
                        <button class="btn btn-outline-danger" onclick="deleteTemplate(${item.id}, '${jsString(item.name)}')">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </td>
            </tr>
        `).join('');
    }

    function openCreateModal() {
        document.getElementById('templateModalTitle').textContent = 'Új sablon';
        document.getElementById('templateId').value = '';
        document.getElementById('templateName').value = '';
        document.getElementById('templateSubject').value = '';
        document.getElementById('templateDescription').value = '';
        document.getElementById('templateBody').value = '';
        document.getElementById('templateIsActive').checked = true;
    }

    async function openEditModal(id) {
        const response = await fetch(`/api/Email/templates/${id}`);
        if (!response.ok) {
            alert('Nem sikerült betölteni a sablon adatait.');
            return;
        }

        const item = await response.json();

        document.getElementById('templateModalTitle').textContent = 'Sablon szerkesztése';
        document.getElementById('templateId').value = item.id;
        document.getElementById('templateName').value = item.name ?? '';
        document.getElementById('templateSubject').value = item.subject ?? '';
        document.getElementById('templateDescription').value = item.description ?? '';
        document.getElementById('templateBody').value = item.body ?? '';
        document.getElementById('templateIsActive').checked = item.isActive;

        templateModal.show();
    }

    async function openDetailsModal(id) {
        const response = await fetch(`/api/Email/templates/${id}`);
        if (!response.ok) {
            alert('Nem sikerült betölteni a részleteket.');
            return;
        }

        const item = await response.json();

        document.getElementById('templateModalTitle').textContent = 'Sablon részletei';
        document.getElementById('templateId').value = item.id;
        document.getElementById('templateName').value = item.name ?? '';
        document.getElementById('templateSubject').value = item.subject ?? '';
        document.getElementById('templateDescription').value = item.description ?? '';
        document.getElementById('templateBody').value = item.body ?? '';
        document.getElementById('templateIsActive').checked = item.isActive;

        templateModal.show();
    }

    async function saveTemplate() {
        const id = document.getElementById('templateId').value;
        const isEdit = !!id;

        const payload = {
            name: document.getElementById('templateName').value.trim(),
            subject: document.getElementById('templateSubject').value.trim(),
            description: document.getElementById('templateDescription').value.trim(),
            body: document.getElementById('templateBody').value,
            isActive: document.getElementById('templateIsActive').checked
        };

        if (!payload.name || !payload.subject || !payload.body) {
            alert('A név, tárgy és törzs mező kötelező.');
            return;
        }

        const response = await fetch(isEdit ? `/api/Email/templates/${id}` : '/api/Email/templates', {
            method: isEdit ? 'PUT' : 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(payload)
        });

        if (!response.ok) {
            let message = 'Mentés sikertelen.';
            try {
                const error = await response.json();
                message = error.message ?? message;
            } catch {}
            alert(message);
            return;
        }

        templateModal.hide();
        await loadTemplates();
    }

    async function deleteTemplate(id, name) {
        if (!confirm(`Biztosan törölni szeretnéd ezt a sablont: ${name}?`)) {
            return;
        }

        const response = await fetch(`/api/Email/templates/${id}`, {
            method: 'DELETE'
        });

        if (!response.ok) {
            alert('Törlés sikertelen.');
            return;
        }

        await loadTemplates();
    }

    function escapeHtml(value) {
        return String(value ?? '')
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');
    }

    function jsString(value) {
        return String(value ?? '').replaceAll("'", "\\'");
    }
</script>
}