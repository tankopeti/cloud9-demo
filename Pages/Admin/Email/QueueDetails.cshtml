@page "{id:int}"
@model Cloud9_2.Pages.Admin.Email.QueueDetailsModel
@{
    Layout = "/Pages/Admin/_Layout.cshtml";
    ViewData["Title"] = "Queue részletek";
}

<div class="mb-4">
    <h1 class="h3 fw-bold mb-1">Queue részletek</h1>
    <p class="text-muted mb-0">Email küldési tétel részletei.</p>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">ID</dt>
            <dd class="col-sm-9">@Model.Item.Id</dd>

            <dt class="col-sm-3">Címzett</dt>
            <dd class="col-sm-9">@Model.Item.To</dd>

            <dt class="col-sm-3">Tárgy</dt>
            <dd class="col-sm-9">@Model.Item.Subject</dd>

            <dt class="col-sm-3">Státusz</dt>
            <dd class="col-sm-9">@Model.Item.Status</dd>

            <dt class="col-sm-3">Body</dt>
            <dd class="col-sm-9">
                <pre class="bg-light p-3 rounded">@Model.Item.Body</pre>
            </dd>
        </dl>
    </div>
</div>