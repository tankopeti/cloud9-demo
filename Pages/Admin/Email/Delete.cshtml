@page "{id:int}"
@model Cloud9_2.Pages.Admin.Email.DeleteModel
@{
    Layout = "/Pages/Admin/_Layout.cshtml";
    ViewData["Title"] = "Email sablon törlése";
}

<div class="mb-4">
    <h1 class="h3 fw-bold text-danger">Email sablon törlése</h1>
    <p class="text-muted mb-0">Biztosan törölni szeretnéd ezt a sablont?</p>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Név</dt>
            <dd class="col-sm-9">@Model.Template.Name</dd>

            <dt class="col-sm-3">Tárgy</dt>
            <dd class="col-sm-9">@Model.Template.Subject</dd>
        </dl>

        <form method="post">
            <input asp-for="Template.Id" type="hidden" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Törlés</button>
                <a asp-page="./Index" class="btn btn-outline-secondary">Mégse</a>
            </div>
        </form>
    </div>
</div>