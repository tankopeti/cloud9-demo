@page
@model Cloud9_2.Pages.Admin.AccesPermissions.IndexModel
@{
    Layout = "/Pages/Admin/_Layout.cshtml";
    ViewData["Title"] = "Manage Access Permissions";
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
                <li class="breadcrumb-item"><a href="/">Főoldal</a></li>
                <li class="breadcrumb-item"><a href="/Admin/Index">Admin dashboard</a></li>
                <li class="breadcrumb-item active" aria-current="page">Access Permissions</li>
            </ol>
        </nav>

        <h1 class="h3 mb-1 fw-bold d-flex align-items-center gap-2">
            <i class="bi bi-shield-check"></i>
            <span>Manage Access Permissions</span>
        </h1>

        <p class="text-muted mb-0">Oldal- és oszlopszintű jogosultságok kezelése szerepkörök szerint</p>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-header bg-white border-0 pt-4 px-4">
        <h5 class="mb-0 fw-semibold">Add Permission</h5>
    </div>
    <div class="card-body px-4 pb-4">
        <form method="post">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="NewPermission.RoleId" class="form-label">Role</label>
                    <select asp-for="NewPermission.RoleId"
                            class="form-select"
                            asp-items="@(new SelectList(Model.Roles, "Id", "Name"))">
                        <option value="">Select a role</option>
                    </select>
                    <span asp-validation-for="NewPermission.RoleId" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="NewPermission.PagePath" class="form-label">Page Path</label>
                    <input asp-for="NewPermission.PagePath" class="form-control" />
                    <span asp-validation-for="NewPermission.PagePath" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="NewPermission.ColumnName" class="form-label">Column Name (optional)</label>
                    <input asp-for="NewPermission.ColumnName"
                           class="form-control"
                           placeholder="e.g., Name, Email" />
                </div>

                <div class="col-md-3 d-flex align-items-end">
                    <div class="form-check mb-2">
                        <input asp-for="NewPermission.CanViewPage" class="form-check-input" />
                        <label asp-for="NewPermission.CanViewPage" class="form-check-label">Can View Page</label>
                    </div>
                </div>

                <div class="col-md-3 d-flex align-items-end">
                    <div class="form-check mb-2">
                        <input asp-for="NewPermission.CanViewColumn" class="form-check-input" />
                        <label asp-for="NewPermission.CanViewColumn" class="form-check-label">Can View Column</label>
                    </div>
                </div>

                <div class="col-12">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-1"></i>Add
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-header bg-white border-0 pt-4 px-4">
        <h5 class="mb-0 fw-semibold">Current Permissions</h5>
    </div>

    <div class="card-body px-0 pt-3 pb-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Role</th>
                        <th>Page Path</th>
                        <th>Can View Page</th>
                        <th>Column Name</th>
                        <th>Can View Column</th>
                        <th class="pe-4 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var perm in Model.Permissions)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold">
                                @(Model.Roles.FirstOrDefault(r => r.Id == perm.RoleId)?.Name ?? "Unknown")
                            </td>
                            <td>@perm.PagePath</td>
                            <td>
                                @if (perm.CanViewPage)
                                {
                                    <span class="badge text-bg-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">No</span>
                                }
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(perm.ColumnName) ? "N/A" : perm.ColumnName)</td>
                            <td>
                                @if (perm.CanViewColumn)
                                {
                                    <span class="badge text-bg-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">No</span>
                                }
                            </td>
                            <td class="pe-4 text-end">
                                <form method="post"
                                      asp-page-handler="Delete"
                                      asp-route-id="@perm.AccessPermissionId"
                                      class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }

                    @if (!Model.Permissions.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                Nincs még felvett jogosultság.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <style>
        .table th,
        .table td {
            padding: 0.85rem 1rem;
        }

        .form-label {
            font-weight: 500;
        }
    </style>
}