@* Pages/Admin/Roles/_RoleModals.cshtml *@

<div class="modal fade" id="addRoleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add New Role</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addRoleForm" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label for="roleName" class="form-label">Role Name</label>
                        <input type="text"
                               class="form-control"
                               id="roleName"
                               name="RoleName"
                               required />
                        <div class="invalid-feedback">Please provide a role name.</div>
                    </div>

                    <div id="addRoleError" class="alert alert-danger d-none mb-0"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary" form="addRoleForm" id="saveRoleBtn">Save</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editRoleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Role</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="editRoleForm" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" id="editRoleId" name="Id" />

                    <div class="mb-3">
                        <label for="editRoleName" class="form-label">Role Name</label>
                        <input type="text"
                               class="form-control"
                               id="editRoleName"
                               name="Name"
                               required />
                        <div class="invalid-feedback">Please provide a role name.</div>
                    </div>

                    <div id="editRoleError" class="alert alert-danger d-none mb-0"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary" form="editRoleForm" id="updateRoleBtn">Save Changes</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteRoleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Role</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="deleteRoleForm" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" id="deleteRoleId" name="id" />

                    <p class="mb-2">Are you sure you want to delete this role?</p>
                    <p class="fw-semibold mb-0" id="deleteRoleName"></p>

                    <div id="deleteRoleError" class="alert alert-danger d-none mt-3 mb-0"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-danger" form="deleteRoleForm" id="confirmDeleteRoleBtn">Delete</button>
            </div>
        </div>
    </div>
</div>