@page
@model Cloud9_2.Pages.Admin.Roles.IndexModel
@{
    Layout = "/Pages/Admin/_Layout.cshtml";
    ViewData["Title"] = "Jogosultság típusok";
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
                <li class="breadcrumb-item"><a href="../../">Főoldal</a></li>
                <li class="breadcrumb-item"><a href="../">Admin dashboard</a></li>
                <li class="breadcrumb-item active" aria-current="page">Jogosultság típusok</li>
            </ol>
        </nav>

        <h1 class="h3 mb-1 fw-bold d-flex align-items-center gap-2">
            <i class="bi bi-shield-lock"></i>
            <span>Jogosultság típusok</span>
        </h1>

        <p class="text-muted mb-0">Rendszer szerepkörök kezelése</p>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <button type="button"
                        class="btn btn-primary"
                        data-bs-toggle="modal"
                        data-bs-target="#addRoleModal">
                    <i class="bi bi-plus-circle me-1"></i>Add New Role
                </button>
            </div>

            <div class="d-flex align-items-center gap-2">
                <div class="input-group" style="max-width: 280px;">
                    <input type="text"
                           class="form-control"
                           placeholder="Search roles..."
                           id="searchInput" />
                    <button class="btn btn-outline-secondary" type="button" tabindex="-1">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" id="rolesTable">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Role ID</th>
                    <th>Role Name</th>
                    <th>Normalized Name</th>
                    <th class="pe-4 text-end">Actions</th>
                </tr>
            </thead>
<tbody>
    @if (Model.Roles != null && Model.Roles.Any())
    {
        @foreach (var role in Model.Roles)
        {
            <tr data-role-id="@role.Id">
                <td class="ps-4 text-truncate" style="max-width: 220px;">@role.Id</td>
                <td class="role-name">@role.Name</td>
                <td class="role-normalized-name">@role.NormalizedName</td>
                <td class="pe-4 text-end">
                    <div class="btn-group btn-group-sm" role="group" aria-label="Role actions">
                        <button type="button"
                                class="btn btn-outline-primary edit-role"
                                data-bs-toggle="modal"
                                data-bs-target="#editRoleModal"
                                data-role-id="@role.Id"
                                data-role-name="@role.Name"
                                title="Edit role">
                            <i class="bi bi-pencil-square"></i>
                        </button>

                        <button type="button"
                                class="btn btn-outline-danger delete-role"
                                data-bs-toggle="modal"
                                data-bs-target="#deleteRoleModal"
                                data-role-id="@role.Id"
                                data-role-name="@role.Name"
                                title="Delete role">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </td>
            </tr>
        }
    }
    else
    {
        <tr id="emptyRolesRow">
            <td colspan="4" class="text-center text-muted py-4">Nincs szerepkör.</td>
        </tr>
    }
</tbody>
        </table>
    </div>
</div>

<div class="mt-4">
    <a asp-page="/Admin/Users" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Users
    </a>
</div>

<partial name="_RoleModals" />

@section Scripts {
    <script src="~/js/admin/roles/rolesManagement.js" asp-append-version="true"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const searchInput = document.getElementById('searchInput');
            const tableBody = document.querySelector('#rolesTable tbody');

            if (!searchInput || !tableBody) {
                console.error('Roles search initialization failed');
                return;
            }

            searchInput.addEventListener('input', function (e) {
                const searchTerm = (e.target.value || '').toLowerCase().trim();
                const rows = tableBody.querySelectorAll('tr[data-role-id]');
                let visibleCount = 0;

                rows.forEach(row => {
                    const roleName = row.querySelector('.role-name')?.textContent.toLowerCase() || '';
                    const normalizedName = row.querySelector('.role-normalized-name')?.textContent.toLowerCase() || '';
                    const matches = roleName.includes(searchTerm) || normalizedName.includes(searchTerm);

                    row.style.display = matches ? '' : 'none';

                    if (matches) {
                        visibleCount++;
                    }
                });

                let emptySearchRow = document.getElementById('emptySearchRow');

                if (visibleCount === 0 && rows.length > 0) {
                    if (!emptySearchRow) {
                        emptySearchRow = document.createElement('tr');
                        emptySearchRow.id = 'emptySearchRow';
                        emptySearchRow.innerHTML = `
                            <td colspan="4" class="text-center text-muted py-4">
                                Nincs találat a keresésre.
                            </td>
                        `;
                        tableBody.appendChild(emptySearchRow);
                    }
                } else {
                    if (emptySearchRow) {
                        emptySearchRow.remove();
                    }
                }
            });
        });
    </script>

    <style>
        .table th,
        .table td {
            padding: 0.75rem 1rem;
        }
    </style>
}