@page
@model Cloud9_2.Pages.Admin.LoginLogModel
@{
    Layout = "/Pages/Admin/_Layout.cshtml";
    ViewData["Title"] = "Login-Out Log";
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
                <li class="breadcrumb-item"><a href="/">Főoldal</a></li>
                <li class="breadcrumb-item"><a href="/Admin/Index">Admin dashboard</a></li>
                <li class="breadcrumb-item active" aria-current="page">Login-Out Log</li>
            </ol>
        </nav>

        <h1 class="h3 mb-1 fw-bold d-flex align-items-center gap-2">
            <i class="bi bi-clock-history"></i>
            <span>Login-Out Log</span>
        </h1>

        <p class="text-muted mb-0">Records Count: @(Model.UserActivities?.Count ?? 0)</p>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <label for="searchInput" class="form-label">Felhasználónév</label>
                <input type="text" id="searchInput" class="form-control" placeholder="Keresés felhasználónévre...">
            </div>

            <div class="col-md-3">
                <label for="dateFrom" class="form-label">Dátumtól</label>
                <input type="text" id="dateFrom" class="form-control" placeholder="YYYY.MM.DD">
            </div>

            <div class="col-md-3">
                <label for="dateTo" class="form-label">Dátumig</label>
                <input type="text" id="dateTo" class="form-control" placeholder="YYYY.MM.DD">
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button type="button" class="btn btn-outline-secondary w-100" id="filterBtn">
                    <i class="bi bi-funnel me-1"></i>Szűrés
                </button>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" id="loginLogTable">
            <thead class="table-light">
                <tr>
                    @if (Model.ColumnVisibility.ContainsKey("UserId") && Model.ColumnVisibility["UserId"])
                    {
                        <th>User ID</th>
                    }
                    @if (Model.ColumnVisibility.ContainsKey("UserName") && Model.ColumnVisibility["UserName"])
                    {
                        <th>Username</th>
                    }
                    @if (Model.ColumnVisibility.ContainsKey("LoginTime") && Model.ColumnVisibility["LoginTime"])
                    {
                        <th>Login Time</th>
                    }
                    @if (Model.ColumnVisibility.ContainsKey("LogoutTime") && Model.ColumnVisibility["LogoutTime"])
                    {
                        <th>Logout Time</th>
                    }
                    @if (Model.ColumnVisibility.ContainsKey("IsActive") && Model.ColumnVisibility["IsActive"])
                    {
                        <th>Active</th>
                    }
                </tr>
            </thead>

            <tbody>
                @if (Model.UserActivities != null && Model.UserActivities.Any())
                {
                    @foreach (var activity in Model.UserActivities)
                    {
                        <tr data-username="@activity.UserName"
                            data-login-date="@activity.LoginTime.ToString("yyyy-MM-dd")">
                            @if (Model.ColumnVisibility.ContainsKey("UserId") && Model.ColumnVisibility["UserId"])
                            {
                                <td>@activity.UserId</td>
                            }
                            @if (Model.ColumnVisibility.ContainsKey("UserName") && Model.ColumnVisibility["UserName"])
                            {
                                <td>@activity.UserName</td>
                            }
                            @if (Model.ColumnVisibility.ContainsKey("LoginTime") && Model.ColumnVisibility["LoginTime"])
                            {
                                <td>@activity.LoginTime.ToString("yyyy.MM.dd HH:mm:ss")</td>
                            }
                            @if (Model.ColumnVisibility.ContainsKey("LogoutTime") && Model.ColumnVisibility["LogoutTime"])
                            {
                                <td>@(activity.LogoutTime.HasValue ? activity.LogoutTime.Value.ToString("yyyy.MM.dd HH:mm:ss") : "N/A")</td>
                            }
                            @if (Model.ColumnVisibility.ContainsKey("IsActive") && Model.ColumnVisibility["IsActive"])
                            {
                                <td>
                                    @if (activity.IsActive)
                                    {
                                        <span class="badge text-bg-success">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-secondary">No</span>
                                    }
                                </td>
                            }
                        </tr>
                    }

                    <tr id="noFilteredRows" style="display:none;">
                        <td colspan="@Math.Max(1, Model.ColumnVisibility.Count(kv => kv.Value))" class="text-center text-muted py-4">
                            Nincs találat a szűrésre.
                        </td>
                    </tr>
                }
                else
                {
                    <tr>
                        <td colspan="@Math.Max(1, Model.ColumnVisibility.Count(kv => kv.Value))" class="text-center text-muted py-4">
                            No records found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function formatDateForInput(date) {
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            return `${year}.${month}.${day}`;
        }

        function inputDateToComparable(dateStr) {
            if (!dateStr) return '';

            const parts = dateStr.split('.');
            if (parts.length !== 3) return '';

            const [year, month, day] = parts;
            return `${year}-${month.padStart(2, '0')}-${day.padStart(2, '0')}`;
        }

        function applyFilters() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase().trim();
            const dateFrom = inputDateToComparable(document.getElementById('dateFrom').value.trim());
            const dateTo = inputDateToComparable(document.getElementById('dateTo').value.trim());

            const rows = document.querySelectorAll('#loginLogTable tbody tr[data-login-date]');
            const noFilteredRows = document.getElementById('noFilteredRows');

            let visibleCount = 0;

            rows.forEach(row => {
                const username = (row.getAttribute('data-username') || '').toLowerCase().trim();
                const loginDate = row.getAttribute('data-login-date') || '';

                const matchesUsername = !searchTerm || username.includes(searchTerm);
                const matchesFrom = !dateFrom || loginDate >= dateFrom;
                const matchesTo = !dateTo || loginDate <= dateTo;

                const visible = matchesUsername && matchesFrom && matchesTo;
                row.style.display = visible ? '' : 'none';

                if (visible) {
                    visibleCount++;
                }
            });

            if (noFilteredRows) {
                noFilteredRows.style.display = visibleCount === 0 ? '' : 'none';
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            const searchInput = document.getElementById('searchInput');
            const dateFromInput = document.getElementById('dateFrom');
            const dateToInput = document.getElementById('dateTo');
            const filterBtn = document.getElementById('filterBtn');

            searchInput?.addEventListener('input', applyFilters);
            dateFromInput?.addEventListener('input', applyFilters);
            dateToInput?.addEventListener('input', applyFilters);
            filterBtn?.addEventListener('click', applyFilters);

            const today = new Date();
            const last30Days = new Date();
            last30Days.setDate(today.getDate() - 30);

            dateFromInput.value = formatDateForInput(last30Days);
            dateToInput.value = formatDateForInput(today);

            applyFilters();
        });
    </script>

<style>
    html, body {
        overflow-y: auto !important;
    }

    main, .container, .container-fluid, .content-wrapper, .page-content {
        overflow: visible !important;
    }

    .table th,
    .table td {
        padding: 0.75rem 1rem;
    }
</style>
}