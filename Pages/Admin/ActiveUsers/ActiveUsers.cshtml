@page
@model Cloud9_2.Pages.Admin.ActiveUsersModel
@{
    Layout = "/Pages/Admin/_Layout.cshtml";
    ViewData["Title"] = "Aktív felhasználók";
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
                <li class="breadcrumb-item"><a href="../../">Főoldal</a></li>
                <li class="breadcrumb-item"><a href="../">Admin dashboard</a></li>
                <li class="breadcrumb-item active" aria-current="page">Aktív felhasználók</li>
            </ol>
        </nav>

        <h1 class="h3 mb-1 fw-bold d-flex align-items-center gap-2">
            <i class="bi bi-broadcast"></i>
            <span>Aktív felhasználók</span>
        </h1>

        <p class="text-muted mb-0">Jelenleg bejelentkezett felhasználók listája</p>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-end">
            <div class="input-group" style="max-width: 280px;">
                <input type="text" class="form-control" placeholder="Search users..." id="searchInput">
                <button class="btn btn-outline-secondary" type="button" id="searchButton">
                    <i class="bi bi-search"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" id="activeUsersTable">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Username</th>
                    <th>Login Time</th>
                </tr>
            </thead>
            <tbody id="activeUsersTableBody">
                @if (Model.ActiveUsers != null && Model.ActiveUsers.Any())
                {
                    @foreach (var user in Model.ActiveUsers)
                    {
                        <tr data-username="@user.UserName">
                            <td class="ps-4 online-user">@user.UserName</td>
                            <td>@user.LoginTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr id="emptyUsersRow">
                        <td colspan="2" class="text-center text-muted py-4">Nincs aktív felhasználó.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/signalr.min.js"></script>
    <script>
        const tableBody = document.getElementById('activeUsersTableBody');
        const searchInput = document.getElementById('searchInput');
        const searchButton = document.getElementById('searchButton');

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/userActivityHub")
            .withAutomaticReconnect()
            .build();

        function escapeHtml(value) {
            return String(value ?? '')
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#39;');
        }

        function normalizeUsername(value) {
            return String(value ?? '').trim().toLowerCase();
        }

        function parseDateSafe(value) {
            const date = new Date(value);
            return isNaN(date.getTime()) ? null : date;
        }

        function formatDate(value) {
            const date = parseDateSafe(value);
            if (!date) {
                return escapeHtml(value ?? '');
            }

            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            const hours = String(date.getHours()).padStart(2, '0');
            const minutes = String(date.getMinutes()).padStart(2, '0');
            const seconds = String(date.getSeconds()).padStart(2, '0');

            return `${year}-${month}-${day} ${hours}:${minutes}:${seconds}`;
        }

        function deduplicateUsers(users) {
            const map = new Map();

            (users || []).forEach(user => {
                const rawUserName = user.userName ?? user.UserName ?? '';
                const rawLoginTime = user.loginTime ?? user.LoginTime ?? '';

                const key = normalizeUsername(rawUserName);
                if (!key) return;

                const existing = map.get(key);

                if (!existing) {
                    map.set(key, {
                        userName: rawUserName,
                        loginTime: rawLoginTime
                    });
                    return;
                }

                const currentDate = parseDateSafe(rawLoginTime);
                const existingDate = parseDateSafe(existing.loginTime);

                if (currentDate && existingDate) {
                    if (currentDate > existingDate) {
                        map.set(key, {
                            userName: rawUserName,
                            loginTime: rawLoginTime
                        });
                    }
                } else {
                    map.set(key, {
                        userName: rawUserName,
                        loginTime: rawLoginTime
                    });
                }
            });

            return Array.from(map.values()).sort((a, b) => {
                const da = parseDateSafe(a.loginTime);
                const db = parseDateSafe(b.loginTime);

                if (da && db) return db - da;
                return String(b.loginTime).localeCompare(String(a.loginTime));
            });
        }

        function renderUsers(users) {
            tableBody.innerHTML = '';

            const uniqueUsers = deduplicateUsers(users);

            if (!uniqueUsers.length) {
                tableBody.innerHTML = `
                    <tr id="emptyUsersRow">
                        <td colspan="2" class="text-center text-muted py-4">Nincs aktív felhasználó.</td>
                    </tr>
                `;
                return;
            }

            uniqueUsers.forEach(user => {
                const tr = document.createElement('tr');
                tr.setAttribute('data-username', user.userName);

                tr.innerHTML = `
                    <td class="ps-4 online-user">${escapeHtml(user.userName)}</td>
                    <td>${formatDate(user.loginTime)}</td>
                `;

                tableBody.appendChild(tr);
            });

            applyUsernameFilter();
        }

        function applyUsernameFilter() {
            const searchTerm = (searchInput.value || '').trim().toLowerCase();
            const rows = tableBody.querySelectorAll('tr[data-username]');

            rows.forEach(row => {
                const username = row.getAttribute('data-username')?.toLowerCase() || '';
                const displayName = row.querySelector('td:first-child')?.textContent.toLowerCase() || '';

                if (!searchTerm) {
                    row.style.display = '';
                    return;
                }

                const matches = username.includes(searchTerm) || displayName.includes(searchTerm);
                row.style.display = matches ? '' : 'none';
            });
        }

        connection.on("ReceiveActiveUsers", function (users) {
            renderUsers(users);
        });

        connection.start()
            .then(() => {
                console.log("SignalR connected for ActiveUsers page");
                return connection.invoke("GetActiveUsers");
            })
            .catch(err => console.error("SignalR connection failed:", err));

        let searchTimeout;

        searchInput.addEventListener('input', function () {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(applyUsernameFilter, 300);
        });

        searchButton.addEventListener('click', applyUsernameFilter);

        searchInput.addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
                applyUsernameFilter();
            }
        });

        window.addEventListener('beforeunload', () => {
            connection.stop();
        });
    </script>

    <style>
        .table th,
        .table td {
            padding: 0.75rem 1rem;
        }

        .online-user {
            color: green;
            font-weight: bold;
        }
    </style>
}